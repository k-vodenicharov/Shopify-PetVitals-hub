{{ 'petvitals-custom.css' | asset_url | stylesheet_tag }}

<!-- PRODUCT VIDEO / GIF PLACEHOLDER
     Replace the placeholder div below with your actual <video> or <img> tag
     when you have the final media asset ready. -->
<div class="pvh-product-video-section">
  <div class="pvh-product-video-placeholder">
    <div class="pvh-product-video-inner">
      <span class="pvh-product-video-icon">▶</span>
      <p class="pvh-product-video-label">Product Video Coming Soon</p>
      <p class="pvh-product-video-sub">Upload your GIF or video here</p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "PVH Product Video",
  "settings": [],
  "presets": [{"name": "PVH Product Video"}]
}
{% endschema %}

{{ 'petvitals-custom.css' | asset_url | stylesheet_tag }}

<!-- OUTCOME STATS STRIP -->
<div class="pvh-lp-stats-strip">
  <div class="pvh-lp-stats-inner">
    <div class="pvh-lp-stat">
      <div class="pvh-lp-stat-num">More</div>
      <div class="pvh-lp-stat-label">water intake than a still bowl</div>
    </div>
    <div class="pvh-lp-stat-divider" aria-hidden="true"></div>
    <div class="pvh-lp-stat">
      <div class="pvh-lp-stat-num">25 dB</div>
      <div class="pvh-lp-stat-label">Near-silent — quieter than a fridge</div>
    </div>
    <div class="pvh-lp-stat-divider" aria-hidden="true"></div>
    <div class="pvh-lp-stat">
      <div class="pvh-lp-stat-num">3-layer</div>
      <div class="pvh-lp-stat-label">Filtration — always fresh</div>
    </div>
  </div>
</div>

<!-- FEATURE DEEP DIVE -->
<div class="pvh-lp-features">
  <div class="pvh-section-header">
    <span class="pvh-section-tag">What makes Brook different</span>
    <h2 class="pvh-section-title pvh-section-title--lp-features">Every detail designed around how cats actually drink — and what keeps that water safe.</h2>
  </div>
  <div class="pvh-lp-features-list">

    <div class="pvh-lp-feature">
      <div class="pvh-lp-feature-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2c0 6-8 10-8 14a8 8 0 0 0 16 0c0-4-8-8-8-14z"/></svg>
      </div>
      <div class="pvh-lp-feature-body">
        <h3>Triple-stage filtration</h3>
        <p>Three layers — foam catches fur and food debris, activated carbon removes odours and chlorine, cotton polishes out fine particles. The filter slots out in seconds for monthly replacement. Cats and dogs both drink more from clean, flowing water.</p>
      </div>
    </div>

    <div class="pvh-lp-feature">
      <div class="pvh-lp-feature-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
      </div>
      <div class="pvh-lp-feature-body">
        <h3>USB-powered — place it anywhere</h3>
        <p>Runs on a standard USB cable and adapter, so there's no mains-only socket to plan around. Put it in the corner of the kitchen, on the hallway floor, beside your pet's bed — wherever they actually drink.</p>
      </div>
    </div>

    <div class="pvh-lp-feature">
      <div class="pvh-lp-feature-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
      </div>
      <div class="pvh-lp-feature-body">
        <h3>Whisper-quiet motor</h3>
        <p>Under 25 decibels — quieter than a household fridge. Shy cats won't bolt at startup noise, anxious dogs won't fixate on the hum. It simply runs, all day, without drawing attention to itself.</p>
      </div>
    </div>

  </div>
</div>

<!-- REVIEWS -->
<div class="pvh-lp-reviews">
  <div class="pvh-lp-reviews-inner">
    <div id="reviews-app-placeholder"></div>
  </div>
</div>

<!-- GUARANTEE -->
<div class="pvh-guarantee-v2">
  <div class="pvh-guarantee-v2-inner">
    <div class="pvh-guarantee-v2-shield">
      <svg xmlns="http://www.w3.org/2000/svg" width="84" height="84" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.4 9.4 8 11 4.6-1.6 8-6 8-11V5l-8-3z"/><path d="m9 12 2 2 4-4"/></svg>
    </div>
    <div class="pvh-guarantee-v2-text">
      <span class="pvh-section-tag">Our promise</span>
      <h2 class="pvh-guarantee-v2-title">If your pet won't drink from Brook, we'll refund every cent.</h2>
      <p class="pvh-guarantee-v2-body">Try Brook for 30 full days. If your cat ignores it, hates it, or you just change your mind — email us. We'll refund your full purchase price. You don't need to return the fountain. We trust your judgement; we believe in the product.</p>
      <p class="pvh-guarantee-v2-sign">— The PetVitals team</p>
    </div>
  </div>
</div>

<!-- FAQ -->
<section class="pvh-faq">
  <div class="pvh-faq-inner">
    <div class="pvh-section-header">
      <span class="pvh-section-tag">Common questions</span>
      <h2 class="pvh-section-title">Things pet parents ask before buying</h2>
    </div>
    <div class="pvh-faq-grid">
      <details class="pvh-faq-item">
        <summary>Will my pet actually use it? <span class="pvh-faq-chevron" aria-hidden="true">+</span></summary>
        <div class="pvh-faq-answer">Most cats and dogs approach Brook within the first few hours. Some take a day or two. We've never seen a pet completely ignore running water — their instinct is to investigate it. If yours is the exception, our 30-day refund covers you completely.</div>
      </details>
      <details class="pvh-faq-item">
        <summary>How loud is the pump? <span class="pvh-faq-chevron" aria-hidden="true">+</span></summary>
        <div class="pvh-faq-answer">Under 25 decibels — quieter than a household fridge. Most owners forget it's running until they hear their pet drinking from it.</div>
      </details>
      <details class="pvh-faq-item">
        <summary>How long does shipping take? <span class="pvh-faq-chevron" aria-hidden="true">+</span></summary>
        <div class="pvh-faq-answer">EU orders typically arrive in 8–17 business days. You'll receive a tracking number by email once your order ships. If your order hasn't arrived within 21 business days, contact us and we'll sort it immediately.</div>
      </details>
      <details class="pvh-faq-item">
        <summary>Is it dishwasher safe? <span class="pvh-faq-chevron" aria-hidden="true">+</span></summary>
        <div class="pvh-faq-answer">Yes. The removable bowl and tray go on the top rack. Keep the motor unit dry and wipe the base with a damp cloth. Replace the filter monthly for best results.</div>
      </details>
      <details class="pvh-faq-item">
        <summary>How often do I replace the filter? <span class="pvh-faq-chevron" aria-hidden="true">+</span></summary>
        <div class="pvh-faq-answer">Once a month with regular use. The triple-stage filter lasts about 30 days before it saturates. We recommend marking the date on your calendar when you first set it up.</div>
      </details>
      <details class="pvh-faq-item">
        <summary>What's in the box? <span class="pvh-faq-chevron" aria-hidden="true">+</span></summary>
        <div class="pvh-faq-answer">Brook fountain bowl + base, USB circulation pump, 1× triple-stage filter cartridge, USB cable and adapter, and a setup guide. Everything you need, nothing you don't.</div>
      </details>
    </div>
  </div>
</section>

<!-- FINAL CTA — scrolls back to the buy box rather than re-linking to this page -->
<div class="pvh-cta-section">
  <h2 class="pvh-cta-title">Give your pet the water<br>they actually want.</h2>
  <p class="pvh-cta-section-sub">From {{ product.selected_or_first_available_variant.price | money }} · Free EU shipping over €50 · 30-day money-back guarantee</p>
  <button type="button" class="pvh-cta-btn" data-pvh-scroll-to-hero>Order Brook Now</button>
</div>

<script>
  (function () {
    var btns = document.querySelectorAll('[data-pvh-scroll-to-hero]');
    if (!btns.length) return;
    btns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var hero = document.getElementById('pvh-product-hero');
        if (!hero) return;
        hero.scrollIntoView({ behavior: 'smooth', block: 'start' });
        // After scroll completes, focus the primary ATC for keyboard users
        setTimeout(function () {
          var atc = document.getElementById('pvh-atc-main');
          if (atc && typeof atc.focus === 'function') atc.focus({ preventScroll: true });
        }, 600);
      });
    });
  })();
</script>


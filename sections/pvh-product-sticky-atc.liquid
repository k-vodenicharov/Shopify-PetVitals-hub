{{ 'petvitals-custom.css' | asset_url | stylesheet_tag }}

{%- assign product = product -%}
{%- assign first_variant = product.variants.first -%}

<div id="pvh-product-sticky-bar" class="pvh-product-sticky-bar" aria-hidden="true">
  <div class="pvh-product-sticky-inner">
    <div class="pvh-product-sticky-info">
      {%- if product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 80 }}"
          alt="{{ product.title | escape }}"
          class="pvh-product-sticky-img"
          loading="lazy"
          width="80"
          height="80"
        >
      {%- endif -%}
      <div>
        <div class="pvh-product-sticky-name">{{ product.title | escape }}</div>
        <div class="pvh-product-sticky-price">
          {{ first_variant.price | money }}
          <span class="pvh-product-sticky-shipping">FREE SHIPPING</span>
        </div>
      </div>
    </div>
    <button
      type="button"
      class="pvh-product-sticky-btn pvh-product-sticky-atc-btn"
      data-variant="{{ first_variant.id }}"
      style="font-family:inherit;"
    >
      Add to Cart
    </button>
  </div>
</div>

<script>
(function () {
  var stickyBar = document.getElementById('pvh-product-sticky-bar');
  if (!stickyBar) return;

  var atcBtn = stickyBar.querySelector('.pvh-product-sticky-atc-btn');

  function getSelectedVariantId() {
    var input = document.querySelector('input[name="id"][form]') ||
                document.querySelector('form[action*="/cart/add"] input[name="id"]') ||
                document.querySelector('.product-form__input input[name="id"]');
    if (input) return parseInt(input.value, 10);
    var sel = document.querySelector('select[name="id"]');
    if (sel) return parseInt(sel.value, 10);
    return parseInt(atcBtn.getAttribute('data-variant'), 10);
  }

  function syncVariant() {
    var id = getSelectedVariantId();
    if (id) atcBtn.setAttribute('data-variant', id);
  }

  document.addEventListener('variant:changed', syncVariant);
  document.addEventListener('change', function (e) {
    if (e.target && (e.target.name === 'id' || e.target.closest('.product-form__input'))) {
      syncVariant();
    }
  });
  setTimeout(syncVariant, 300);

  var mainBtn = document.querySelector('.shopify-payment-button, [data-testid="Checkout-button"], form[action*="/cart/add"] button[type="submit"], .product-form__submit');
  if (mainBtn && window.IntersectionObserver) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        stickyBar.classList.toggle('pvh-product-sticky-visible', !entry.isIntersecting);
        stickyBar.setAttribute('aria-hidden', entry.isIntersecting ? 'true' : 'false');
      });
    }, { threshold: 0 });
    observer.observe(mainBtn);
  } else {
    window.addEventListener('scroll', function () {
      var scrolled = window.pageYOffset > 500;
      stickyBar.classList.toggle('pvh-product-sticky-visible', scrolled);
      stickyBar.setAttribute('aria-hidden', scrolled ? 'false' : 'true');
    }, { passive: true });
  }

  if (atcBtn) {
    atcBtn.addEventListener('click', function () {
      syncVariant();
      var variantId = parseInt(atcBtn.getAttribute('data-variant'), 10);
      if (!variantId) return;
      var orig = atcBtn.textContent;
      atcBtn.disabled = true;
      atcBtn.textContent = 'Adding...';
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ id: variantId, quantity: 1 })
      })
      .then(function (r) { return r.json(); })
      .then(function () {
        atcBtn.textContent = 'Added ✓';
        setTimeout(function () { atcBtn.disabled = false; atcBtn.textContent = orig; }, 2800);
      })
      .catch(function () { atcBtn.disabled = false; atcBtn.textContent = orig; });
    });
  }
})();
</script>

{% schema %}
{
  "name": "PVH Product Sticky ATC",
  "settings": [],
  "presets": [{"name": "PVH Product Sticky ATC"}]
}
{% endschema %}

{%- comment -%}
  dynamic-pet-showcase.liquid
  Three.js 3D product showcase with GSAP hover interactions.

  Collection source: pet-health-wellness
  Falls back to the 'brook' product if the collection has no products.

  Depends on Three.js and GSAP loaded globally from layout/theme.liquid.

  NOTE — Tailwind: uses the Play CDN (JIT at runtime). For production,
  compile a Tailwind CSS asset via CLI and upload to /assets instead.
{%- endcomment -%}

{%- assign _col  = collections['pet-health-wellness'] -%}
{%- assign _prod = _col.products.first -%}
{%- unless _prod -%}
  {%- assign _prod = all_products['brook'] -%}
{%- endunless -%}
{%- assign _img_url  = _prod.featured_image | image_url: width: 800 -%}
{%- assign _dest_url = _col.url | default: _prod.url -%}
{%- assign _count    = _col.products_count | default: 0 -%}

{{ 'petvitals-custom.css' | asset_url | stylesheet_tag }}

<!-- Tailwind Play CDN — synchronous by design; scans DOM on load, defer/async causes FOUC -->
{% # theme-check-disable ParserBlockingScript, RemoteAsset %}
<script src="https://cdn.tailwindcss.com"></script>
{% # theme-check-enable ParserBlockingScript, RemoteAsset %}
<script>
  tailwind.config = {
    corePlugins: { preflight: false },   /* prevent reset from overriding theme styles */
    theme: {
      extend: {
        colors: {
          'pvh-green':      '#2D6A4F',
          'pvh-green-dark': '#1B4332',
          'pvh-green-mid':  '#52B788',
          'pvh-green-pale': '#EAF4EE',
          'pvh-green-tint': '#F4FAF6',
          'pvh-white':      '#FAFAF8',
          'pvh-black':      '#0D1B12',
          'pvh-muted':      '#6B7B72',
          'pvh-border':     '#E2ECE6',
        },
        fontFamily: {
          sans: ['var(--font-primary--family)', 'system-ui', 'sans-serif'],
        },
        boxShadow: {
          'pvh-cta':       '0 4px 18px rgba(45,106,79,0.28)',
          'pvh-cta-hover': '0 6px 24px rgba(45,106,79,0.40)',
        },
      },
    },
  };
</script>

<!-- ═══════════════════════════════════════════════════════════
     SECTION WRAPPER
════════════════════════════════════════════════════════════ -->
<section
  class="pvh-showcase bg-pvh-white overflow-hidden"
  id="pvh-dynamic-showcase"
  aria-label="Pet Health &amp; Wellness showcase"
>
  <div class="mx-auto max-w-7xl px-6 py-24 lg:px-16 lg:py-32">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-20">

      <!-- ── LEFT COLUMN: Typography + CTA ──────────────── -->
      <div class="flex flex-col justify-center order-2 lg:order-1">

        <span class="mb-5 inline-block text-xs font-semibold uppercase tracking-[0.18em] text-pvh-green">
          Pet Health &amp; Wellness
        </span>

        <h2 class="font-sans text-[2.6rem] font-bold leading-[1.08] tracking-[-0.03em] text-pvh-black lg:text-[3.25rem]">
          Everything your pet<br>
          needs to <em class="not-italic text-pvh-green">thrive.</em>
        </h2>

        <p class="mt-6 max-w-[42ch] text-[1.0625rem] leading-relaxed text-pvh-muted">
          Vet-formulated supplements and wellness essentials —
          crafted without fillers for the animals that share your home.
        </p>

        <!-- CTA row -->
        <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
          <a
            href="{{ _dest_url }}"
            class="inline-flex items-center justify-center gap-2.5 rounded-full bg-pvh-green px-8 py-[1.0625rem] text-[0.875rem] font-semibold leading-none text-white shadow-pvh-cta transition-all duration-200 hover:bg-pvh-green-dark hover:shadow-pvh-cta-hover"
          >
            View Supplements
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          {%- if _count > 0 -%}
            <span class="text-[0.8125rem] text-pvh-muted">
              {{ _count }} product{%- if _count != 1 -%}s{%- endif -%} &middot; Free EU shipping
            </span>
          {%- endif -%}
        </div>

        <!-- Trust checklist -->
        <ul class="mt-10 flex flex-col gap-3 text-[0.875rem] text-pvh-muted" aria-label="Product promises">
          {%- assign _trust_items = "Vet-approved formulations,No artificial fillers or preservatives,30-day money-back guarantee" | split: "," -%}
          {%- for _item in _trust_items -%}
            <li class="flex items-center gap-3">
              <svg class="shrink-0 text-pvh-green" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {{ _item }}
            </li>
          {%- endfor -%}
        </ul>

      </div>

      <!-- ── RIGHT COLUMN: Three.js canvas ──────────────── -->
      <div class="order-1 flex flex-col items-center justify-center lg:order-2">

        <div
          class="pvh-showcase-stage relative h-[420px] w-full max-w-[520px] overflow-hidden rounded-3xl bg-pvh-green-tint lg:h-[520px]"
          id="pvh-showcase-stage"
        >
          <!-- Three.js renders here -->
          <canvas
            id="pvh-showcase-canvas"
            class="h-full w-full cursor-grab active:cursor-grabbing"
            aria-label="{{ _prod.title | escape }} 3D view"
            data-image="{{ _img_url }}"
          ></canvas>

          <!-- Fallback: shown only if WebGL or texture fails -->
          {%- if _prod.featured_image -%}
            <img
              id="pvh-showcase-fallback"
              src="{{ _prod.featured_image | image_url: width: 600 }}"
              alt="{{ _prod.title | escape }}"
              width="600"
              height="600"
              loading="lazy"
              class="pointer-events-none absolute inset-0 h-full w-full object-contain p-14 opacity-0 transition-opacity duration-500"
              aria-hidden="true"
            >
          {%- endif -%}

          <!-- Ambient glow ring (CSS-only accent) -->
          <div class="pointer-events-none absolute inset-0 rounded-3xl ring-1 ring-inset ring-pvh-green/10" aria-hidden="true"></div>
        </div>

        <!-- Product label pill -->
        {%- if _prod.title -%}
          <div
            class="mt-5 inline-flex items-center gap-2 rounded-full border border-pvh-border bg-white px-5 py-2 text-[0.8125rem] font-medium text-pvh-black shadow-sm"
            aria-hidden="true"
          >
            <span class="h-2 w-2 rounded-full bg-pvh-green-mid"></span>
            {{ _prod.title }}
          </div>
        {%- endif -%}

      </div>

    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════
     THREE.JS + GSAP SCENE
════════════════════════════════════════════════════════════ -->
<script>
(function pvhShowcase() {
  'use strict';

  /* ── Guards ───────────────────────────────────────────────── */
  if (typeof THREE === 'undefined') {
    console.warn('[pvh-showcase] Three.js not loaded — falling back to static image.');
    showFallback();
    return;
  }

  var canvas = document.getElementById('pvh-showcase-canvas');
  if (!canvas) return;

  var imageUrl = canvas.getAttribute('data-image');
  if (!imageUrl) { showFallback(); return; }

  /* ── Renderer ─────────────────────────────────────────────── */
  var W = canvas.offsetWidth  || 520;
  var H = canvas.offsetHeight || 520;

  var renderer = new THREE.WebGLRenderer({ canvas: canvas, alpha: true, antialias: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(W, H);
  renderer.shadowMap.enabled = false;
  renderer.outputColorSpace = THREE.SRGBColorSpace || THREE.LinearSRGBColorSpace || 'srgb';

  /* ── Scene ────────────────────────────────────────────────── */
  var scene = new THREE.Scene();

  /* ── Camera ───────────────────────────────────────────────── */
  var camera = new THREE.PerspectiveCamera(44, W / H, 0.1, 100);
  camera.position.set(0, 0, 3.8);

  /* ── Lighting ─────────────────────────────────────────────── */
  /* Hemisphere: warm sky (green-pale) above, deep green below — gives
     the mesh a natural environmental tint without a full HDRI. */
  var hemi = new THREE.HemisphereLight(0xeaf4ee, 0x1b4332, 0.6);
  scene.add(hemi);

  /* Key light: slightly warm white, high-right */
  var key = new THREE.DirectionalLight(0xfff8f0, 1.6);
  key.position.set(3, 4, 5);
  scene.add(key);

  /* Rim light: cool green tint from behind-left for depth separation */
  var rim = new THREE.DirectionalLight(0x52b788, 0.5);
  rim.position.set(-4, 1, -3);
  scene.add(rim);

  /* ── Geometry: cylinder (supplement-bottle silhouette) ───── */
  var geometry = new THREE.CylinderGeometry(
    0.72,   /* radiusTop    */
    0.72,   /* radiusBottom */
    1.9,    /* height       */
    64,     /* radialSegs   */
    1,      /* heightSegs   */
    false   /* openEnded    */
  );

  /* ── Material: initially neutral, texture applied on load ─── */
  var material = new THREE.MeshStandardMaterial({
    color:     0xfafaf8,
    roughness: 0.42,
    metalness: 0.14,
  });

  /* ── Mesh ─────────────────────────────────────────────────── */
  var mesh = new THREE.Mesh(geometry, material);
  mesh.rotation.x = 0.06;   /* slight forward tilt for depth */
  scene.add(mesh);

  /* ── Texture loading ─────────────────────────────────────── */
  var loader = new THREE.TextureLoader();
  loader.crossOrigin = 'anonymous';
  loader.load(
    imageUrl,
    function onLoad(tex) {
      tex.colorSpace = THREE.SRGBColorSpace || 'srgb';
      tex.minFilter  = THREE.LinearFilter;
      tex.magFilter  = THREE.LinearFilter;
      tex.generateMipmaps = false;
      material.map   = tex;
      material.color.set(0xffffff);
      material.needsUpdate = true;
    },
    undefined,
    function onError() { showFallback(); }
  );

  /* ── GSAP hover interactions ─────────────────────────────── */
  /*
   * We tween a plain `state` object so GSAP controls values that
   * the RAF loop reads each frame — no direct DOM manipulation needed.
   */
  var state = {
    rotSpeed:  0.006,   /* Y-axis auto-rotation speed (rad/frame)     */
    bobAmp:    0.07,    /* vertical bob amplitude (world units)        */
    bobFreq:   0.75,    /* bob oscillation frequency (hz equiv)        */
  };

  /* Pointer tilt targets — lerped in RAF loop */
  var tiltTarget = { x: 0, y: 0 };

  var stageEl = document.getElementById('pvh-showcase-stage');
  if (stageEl) {
    stageEl.addEventListener('mouseenter', function () {
      if (typeof gsap === 'undefined') return;
      gsap.to(mesh.scale, {
        x: 1.09, y: 1.09, z: 1.09,
        duration: 0.5, ease: 'power2.out',
      });
      gsap.to(state, {
        rotSpeed: 0.024, duration: 0.6, ease: 'power2.inOut',
      });
      gsap.to(state, {
        bobAmp: 0.13, bobFreq: 1.15, duration: 0.5, ease: 'power2.out',
      });
    });

    stageEl.addEventListener('mouseleave', function () {
      if (typeof gsap === 'undefined') return;
      gsap.to(mesh.scale, {
        x: 1, y: 1, z: 1,
        duration: 0.7, ease: 'power2.out',
      });
      gsap.to(state, {
        rotSpeed: 0.006, duration: 1.2, ease: 'power2.inOut',
      });
      gsap.to(state, {
        bobAmp: 0.07, bobFreq: 0.75, duration: 0.9, ease: 'power2.out',
      });
      tiltTarget.x = 0;
      tiltTarget.y = 0;
    });

    /* Pointer-tracking tilt: cursor position within the stage drives
       a gentle X/Y rotation offset so the mesh "follows" the mouse. */
    stageEl.addEventListener('mousemove', function (e) {
      var rect = stageEl.getBoundingClientRect();
      var nx =  (e.clientX - rect.left)  / rect.width  - 0.5;   /* -0.5 → +0.5 */
      var ny =  (e.clientY - rect.top)   / rect.height - 0.5;
      tiltTarget.x = -ny * 0.45;   /* pitch:  up/down   */
      tiltTarget.y =  nx * 0.55;   /* yaw:    left/right */
    }, { passive: true });
  }

  /* ── Resize ───────────────────────────────────────────────── */
  var resizeTimer = null;
  window.addEventListener('resize', function () {
    if (resizeTimer) clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function () {
      W = canvas.offsetWidth;
      H = canvas.offsetHeight;
      camera.aspect = W / H;
      camera.updateProjectionMatrix();
      renderer.setSize(W, H);
    }, 100);
  }, { passive: true });

  /* ── Render loop ──────────────────────────────────────────── */
  var clock = new THREE.Clock();
  var rafId = null;

  (function tick() {
    rafId = requestAnimationFrame(tick);
    var t = clock.getElapsedTime();

    /* Continuous Y auto-rotation */
    mesh.rotation.y += state.rotSpeed;

    /* Pointer-driven tilt — exponential ease toward target */
    mesh.rotation.x += (tiltTarget.x - mesh.rotation.x) * 0.055;

    /* Vertical bob */
    mesh.position.y = Math.sin(t * state.bobFreq) * state.bobAmp;

    renderer.render(scene, camera);
  })();

  /* ── Cleanup ──────────────────────────────────────────────── */
  function cleanup() {
    if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
    geometry.dispose();
    if (material.map) material.map.dispose();
    material.dispose();
    renderer.dispose();
  }

  document.addEventListener('shopify:section:unload', function (e) {
    if (!e.detail || !e.detail.sectionId) return;
    if (e.detail.sectionId.indexOf('dynamic-pet-showcase') === -1) return;
    cleanup();
  });

  canvas.addEventListener('webglcontextlost', function (e) {
    e.preventDefault();
    cleanup();
  }, false);

  /* ── Helpers ──────────────────────────────────────────────── */
  function showFallback() {
    var fb = document.getElementById('pvh-showcase-fallback');
    if (fb) fb.style.opacity = '1';
    if (canvas) canvas.style.display = 'none';
  }

})();
</script>

{% schema %}
{
  "name": "Dynamic Pet Showcase",
  "settings": [],
  "presets": [
    {
      "name": "Dynamic Pet Showcase"
    }
  ]
}
{% endschema %}

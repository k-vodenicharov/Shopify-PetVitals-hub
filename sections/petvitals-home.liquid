<script>
document.addEventListener('DOMContentLoaded', function () {

  function pvhAddToCart(btn) {
    var variantId = parseInt(btn.getAttribute('data-variant'), 10);
    if (!variantId) return;
    var originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Adding...';
    fetch('/cart/add.js', {method: 'POST', headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'}, body: JSON.stringify({ id: variantId, quantity: 1 })})
    .then(function (r) { if (!r.ok) throw new Error('cart_error'); return r.json(); })
    .then(function () {
      btn.textContent = 'Added to cart! ✓';
      btn.style.background = '#1B4332';
      return fetch('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    })
    .then(function (r) { return r.json(); })
    .then(function (cart) {
      var selectors = ['.cart-count-bubble', '[data-cart-count]', '.header__cart-count', '.cart-icon-bubble', '.icon-cart-count', '#cart-count', '[data-header-cart-count]', '.cart-link__bubble', '.cart__count', '[data-cart-item-count]'];
      selectors.forEach(function (sel) { document.querySelectorAll(sel).forEach(function (el) { el.textContent = cart.item_count; el.style.display = cart.item_count > 0 ? '' : 'none'; }); });
      setTimeout(function () { btn.disabled = false; btn.textContent = originalText; btn.style.background = ''; }, 3000);
    })
    .catch(function () { btn.disabled = false; btn.textContent = originalText; });
  }

  document.querySelectorAll('.pvh-ajax-atc').forEach(function (btn) { btn.addEventListener('click', function () { pvhAddToCart(this); }); });

  var countdownEl = document.getElementById('pvh-countdown');
  if (countdownEl) {
    var TIMER_KEY = 'pvh_sale_end';
    var endTime = parseInt(localStorage.getItem(TIMER_KEY), 10);
    if (!endTime || Date.now() > endTime) { endTime = Date.now() + 86400000; localStorage.setItem(TIMER_KEY, endTime); }
    function pad2(n) { return n < 10 ? '0' + n : '' + n; }
    function tickTimer() {
      var diff = endTime - Date.now();
      if (diff <= 0) { endTime = Date.now() + 86400000; localStorage.setItem(TIMER_KEY, endTime); diff = 86400000; }
      countdownEl.textContent = pad2(Math.floor(diff / 3600000)) + ':' + pad2(Math.floor((diff % 3600000) / 60000)) + ':' + pad2(Math.floor((diff % 60000) / 1000));
    }
    tickTimer();
    setInterval(tickTimer, 1000);
  }

  var spEl = document.getElementById('pvh-social-proof');
  var spNameEl = document.getElementById('pvh-sp-name');
  if (spEl && spNameEl) {
    var notices = ['🇦🇹 Maria from Vienna just purchased!','🇩🇪 Stefan from Berlin just purchased!','🇬🇧 James from London just purchased!','🇫🇷 Sophie from Paris just purchased!','🇳🇱 Lars from Amsterdam just purchased!','🇪🇸 Carlos from Madrid just purchased!','🇮🇹 Giulia from Rome just purchased!','🇸🇪 Anna from Stockholm just purchased!','🇵🇱 Marek from Warsaw just purchased!','🇧🇪 Lena from Brussels just purchased!'];
    var spIdx = Math.floor(Math.random() * notices.length);
    function showSocialProof() { spNameEl.textContent = notices[spIdx]; spIdx = (spIdx + 1) % notices.length; spEl.classList.add('pvh-sp-show'); setTimeout(function () { spEl.classList.remove('pvh-sp-show'); }, 4000); }
    setTimeout(showSocialProof, 10000);
    setInterval(showSocialProof, 38000);
  }

  var overlayEl = document.getElementById('pvh-overlay');
  if (overlayEl && !localStorage.getItem('pvh_popup_shown')) {
    var popupCloseBtn = document.getElementById('pvh-popup-close');
    var popupSubmit = document.getElementById('pvh-popup-submit');
    var popupEmail = document.getElementById('pvh-popup-email');
    var popupForm = document.getElementById('pvh-popup-form');
    var popupSuccess = document.getElementById('pvh-popup-success');
    setTimeout(function () { overlayEl.classList.add('pvh-overlay-show'); overlayEl.setAttribute('aria-hidden', 'false'); }, 8000);
    function dismissPopup() { overlayEl.classList.remove('pvh-overlay-show'); overlayEl.setAttribute('aria-hidden', 'true'); localStorage.setItem('pvh_popup_shown', '1'); }
    popupCloseBtn.addEventListener('click', dismissPopup);
    overlayEl.addEventListener('click', function (e) { if (e.target === overlayEl) dismissPopup(); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && overlayEl.classList.contains('pvh-overlay-show')) dismissPopup(); });
    popupSubmit.addEventListener('click', function () {
      var email = popupEmail.value.trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { popupEmail.style.borderColor = '#e63946'; popupEmail.focus(); return; }
      popupEmail.style.borderColor = '';
      popupForm.style.display = 'none';
      popupSuccess.style.display = 'block';
      localStorage.setItem('pvh_popup_shown', '1');
    });
    popupEmail.addEventListener('keydown', function (e) { if (e.key === 'Enter') popupSubmit.click(); });
  }

  var stickyBar = document.getElementById('pvh-sticky-bar');
  var heroEl = document.getElementById('pvh-hero');
  var footerEl = document.querySelector('footer, [class*="footer"]');
  if (stickyBar && heroEl) {
    var ticking = false;
    window.addEventListener('scroll', function () {
      if (!ticking) {
        window.requestAnimationFrame(function () {
          var heroPast = heroEl.getBoundingClientRect().bottom < 0;
          var footerNear = footerEl && footerEl.getBoundingClientRect().top < window.innerHeight + 10;
          if (heroPast && !footerNear) {
            stickyBar.classList.add('pvh-sticky-visible');
            stickyBar.classList.remove('pvh-sticky-hidden');
            stickyBar.setAttribute('aria-hidden', 'false');
          } else {
            stickyBar.classList.remove('pvh-sticky-visible');
            stickyBar.classList.add('pvh-sticky-hidden');
            stickyBar.setAttribute('aria-hidden', 'true');
          }
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }

});
</script>


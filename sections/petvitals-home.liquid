        width="{{ product.featured_image.width }}"
        height="{{ product.featured_image.height }}"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="pvh-hero-img"
        id="pvh-hero-img"
        data-threejs-src="{{ product.featured_image | image_url: width: 1400 }}"

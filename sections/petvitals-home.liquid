  </div>

  <!-- ── Image column (full-bleed) ──────────────────── -->
  <div class="pvh-hero-visual" data-pvh-enter style="transition-delay:0.2s" id="pvh-hero-visual">
    <canvas class="pvh-hero-canvas" id="pvh-hero-canvas" aria-hidden="true"></canvas>

  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {

  // ─── AJAX ADD TO CART ─────────────────────────────────────────────
  function pvhAddToCart(btn) {
    var variantId = parseInt(btn.getAttribute('data-variant'), 10);
    if (!variantId) return;
    var originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Adding...';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(function (r) {
      if (!r.ok) throw new Error('cart_error');
      return r.json();
    })
    .then(function () {
      btn.textContent = 'Added to cart! ✓';
      btn.style.background = '#1B4332';
      return fetch('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    })
    .then(function (r) { return r.json(); })
    .then(function (cart) {
      // Update cart count — covers Rebel theme and most Shopify themes
      var selectors = [
        '.cart-count-bubble', '[data-cart-count]', '.header__cart-count',
        '.cart-icon-bubble', '.icon-cart-count', '#cart-count',
        '[data-header-cart-count]', '.cart-link__bubble', '.cart__count',
        '[data-cart-item-count]'
      ];
      selectors.forEach(function (sel) {
        document.querySelectorAll(sel).forEach(function (el) {
          el.textContent = cart.item_count;
          el.style.display = cart.item_count > 0 ? '' : 'none';
        });
      });
      setTimeout(function () {
        btn.disabled = false;
        btn.textContent = originalText;
        btn.style.background = '';
      }, 3000);
    })
    .catch(function () {
      btn.disabled = false;
      btn.textContent = originalText;
    });
  }

  document.querySelectorAll('.pvh-ajax-atc').forEach(function (btn) {
    btn.addEventListener('click', function () { pvhAddToCart(this); });
  });

  // ─── EMAIL POPUP ──────────────────────────────────────────────────
  // ─── STICKY ADD TO CART BAR ───────────────────────────────────────
  var stickyBar = document.getElementById('pvh-sticky-bar');
  var heroEl    = document.getElementById('pvh-hero');
  var footerEl  = document.querySelector('footer, [class*="footer"]');
  if (stickyBar && heroEl) {
    var ticking = false;
    window.addEventListener('scroll', function () {
      if (!ticking) {
        window.requestAnimationFrame(function () {
          var heroPast   = heroEl.getBoundingClientRect().bottom < 0;
          var footerNear = footerEl && footerEl.getBoundingClientRect().top < window.innerHeight + 10;
          if (heroPast && !footerNear) {
            stickyBar.classList.add('pvh-sticky-visible');
            stickyBar.classList.remove('pvh-sticky-hidden');
            stickyBar.setAttribute('aria-hidden', 'false');
          } else {
            stickyBar.classList.remove('pvh-sticky-visible');
            stickyBar.classList.add('pvh-sticky-hidden');
            stickyBar.setAttribute('aria-hidden', 'true');
          }
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }

});
</script>


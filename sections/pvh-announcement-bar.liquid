{{ 'petvitals-custom.css' | asset_url | stylesheet_tag }}

<div class="pvh-announcement-bar" role="region" aria-label="Store announcement">
  <div class="pvh-announcement-bar-track" aria-hidden="true">
    {%- for i in (1..4) -%}
      <span class="pvh-announcement-bar-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9V6a1 1 0 0 1 1-1h11v11H3v-2"/><path d="M15 9h4l3 3v4h-7"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>
        Free shipping on orders over €50
      </span>
      <span class="pvh-announcement-bar-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 5v6c0 5 3.4 9.4 8 11 4.6-1.6 8-6 8-11V5l-8-3z"/><path d="m9 12 2 2 4-4"/></svg>
        30-day money-back guarantee
      </span>
      <span class="pvh-announcement-bar-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
        SSL secured checkout
      </span>
      <span class="pvh-announcement-bar-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9V6a1 1 0 0 1 1-1h11v11H3v-2"/><path d="M15 9h4l3 3v4h-7"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>
        7–14 day EU delivery
      </span>
    {%- endfor -%}
  </div>
  <noscript>
    <p class="pvh-announcement-bar-static">Free shipping on orders over €50 &nbsp;·&nbsp; 30-day money-back guarantee &nbsp;·&nbsp; SSL checkout</p>
  </noscript>
</div>

{% schema %}
{
  "name": "PVH Announcement Bar",
  "settings": [],
  "presets": [{ "name": "PVH Announcement Bar" }]
}
{% endschema %}

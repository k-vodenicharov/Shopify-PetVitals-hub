{%- comment -%}
  pvh-receipt-items.liquid
  Renders the cream paper block inside the receipt drawer.
  Included by sections/pvh-receipt-drawer.liquid and re-fetched
  via the Shopify section rendering API on every cart:update event.

  Metafields read (namespace: pvh_nutrition):
    serving_size, hydration_boost, filter_life,
    uv_sterilization, flow_rate, material

  All visual styling lives in the inline <style> of
  pvh-receipt-drawer.liquid (no Tailwind dependency).
{%- endcomment -%}

{%- if cart.item_count > 0 -%}

{%- assign _date = 'now' | date: '%d/%m/%Y' -%}
{%- assign _time = 'now' | date: '%H:%M' -%}
{%- assign _ref  = cart.token | slice: 0, 8 | upcase -%}

<div class="pvh-receipt-paper">

  <!-- ── Store header ────────────────────────────── -->
  <div class="pvh-rcpt-store">
    <p class="pvh-mono pvh-rcpt-store-name">PET VITALS HUB</p>
    <p class="pvh-mono pvh-rcpt-store-url">petvitalshub.com</p>
    <p class="pvh-mono pvh-rcpt-store-meta">{{ _date }}&nbsp;&nbsp;{{ _time }}</p>
    <p class="pvh-mono pvh-rcpt-store-meta">REF:&nbsp;#{{ _ref }}</p>
  </div>

  <div class="pvh-mono pvh-rcpt-divider">================================</div>

  <!-- ── Line items ─────────────────────────────── -->

    <!-- Column headers -->
    <div class="pvh-mono pvh-rcpt-cols">
      <span class="pvh-rcpt-qty">QTY</span>
      <span class="pvh-rcpt-name">ITEM</span>
      <span class="pvh-rcpt-price">PRICE</span>
    </div>
    <div class="pvh-mono pvh-rcpt-divider pvh-rcpt-divider--dim">--------------------------------</div>

    <!-- ── Line items ──────────────────────────────── -->
    {%- for item in cart.items -%}
      {%- assign _n     = item.product.metafields.pvh_nutrition -%}
      {%- assign _delay = forloop.index | times: 55 -%}
      {%- assign _has_specs = false -%}
      {%- if _n.serving_size or _n.hydration_boost or _n.filter_life or _n.uv_sterilization or _n.flow_rate or _n.material -%}
        {%- assign _has_specs = true -%}
      {%- endif -%}

      <div class="pvh-item-row" style="animation-delay:{{ _delay }}ms;">

        <!-- Main row: qty · name · line price -->
        <div class="pvh-mono pvh-rcpt-main">
          <span class="pvh-rcpt-qty">{{ item.quantity }}x</span>
          <span class="pvh-rcpt-name" title="{{ item.product.title }}">
            {{- item.product.title | truncate: 21, '' -}}
          </span>
          <span class="pvh-rcpt-price">
            {{ item.final_line_price | money }}
          </span>
        </div>

        <!-- Variant -->
        {%- unless item.product.has_only_default_variant -%}
          <p class="pvh-mono pvh-rcpt-variant">
            &#x21B3;&nbsp;{{ item.variant.title }}
          </p>
        {%- endunless -%}

        <!-- Unit price if qty > 1 -->
        {%- if item.quantity > 1 -%}
          <p class="pvh-mono pvh-rcpt-each">
            ({{ item.original_price | money }}&nbsp;each)
          </p>
        {%- endif -%}

        <!-- Selling plan -->
        {%- if item.selling_plan_allocation -%}
          <p class="pvh-mono pvh-rcpt-plan">
            &#x21B3;&nbsp;{{ item.selling_plan_allocation.selling_plan.name }}
          </p>
        {%- endif -%}

        <!-- ── pvh_nutrition specs panel ──────────────── -->
        {%- if _has_specs -%}
          <div class="pvh-rcpt-specs">

            <p class="pvh-mono pvh-rcpt-specs-head">
              &#9632;&nbsp;PRODUCT SPECS
            </p>

            {%- if _n.serving_size -%}
              <div class="pvh-spec-row">
                <span>DAILY INTAKE</span>
                <span>{{ _n.serving_size.value }}</span>
              </div>
            {%- endif -%}

            {%- if _n.hydration_boost -%}
              <div class="pvh-spec-row">
                <span>HYDRATION</span>
                <span>{{ _n.hydration_boost.value }}</span>
              </div>
            {%- endif -%}

            {%- if _n.filter_life -%}
              <div class="pvh-spec-row">
                <span>FILTER LIFE</span>
                <span>{{ _n.filter_life.value }}</span>
              </div>
            {%- endif -%}

            {%- if _n.uv_sterilization -%}
              <div class="pvh-spec-row">
                <span>UV CYCLE</span>
                <span>{{ _n.uv_sterilization.value }}</span>
              </div>
            {%- endif -%}

            {%- if _n.flow_rate -%}
              <div class="pvh-spec-row">
                <span>FLOW RATE</span>
                <span>{{ _n.flow_rate.value }}</span>
              </div>
            {%- endif -%}

            {%- if _n.material -%}
              <div class="pvh-spec-row">
                <span>MATERIAL</span>
                <span>{{ _n.material.value }}</span>
              </div>
            {%- endif -%}

          </div>
        {%- endif -%}

      </div>

      {%- unless forloop.last -%}
        <div class="pvh-mono pvh-rcpt-divider pvh-rcpt-divider--dot">................................</div>
      {%- endunless -%}

    {%- endfor -%}

    <!-- ── Totals ───────────────────────────────────── -->
    <div class="pvh-mono pvh-rcpt-divider pvh-rcpt-divider--total">================================</div>

    {%- if cart.cart_level_discount_applications.size > 0 -%}
      {%- for discount in cart.cart_level_discount_applications -%}
        <div class="pvh-mono pvh-rcpt-totals-line pvh-rcpt-totals-line--discount">
          <span>DISCOUNT: {{ discount.title | upcase | truncate: 18, '' }}</span>
          <span>-{{ discount.total_allocated_amount | money }}</span>
        </div>
      {%- endfor -%}
    {%- endif -%}

    <div class="pvh-mono pvh-rcpt-totals-line pvh-rcpt-totals-line--subtotal">
      <span class="pvh-rcpt-label">SUBTOTAL</span>
      <span class="pvh-rcpt-value">{{ cart.items_subtotal_price | money }}</span>
    </div>
    <div class="pvh-mono pvh-rcpt-totals-line pvh-rcpt-totals-line--free">
      <span class="pvh-rcpt-label">SHIPPING</span>
      <span class="pvh-rcpt-value">FREE (EU)</span>
    </div>

    <div class="pvh-mono pvh-rcpt-divider pvh-rcpt-divider--total-bottom">================================</div>

    <div class="pvh-mono pvh-rcpt-total">
      <span>TOTAL</span>
      <span>
        {%- if settings.currency_code_enabled_cart_total -%}
          {{ cart.total_price | money_with_currency }}
        {%- else -%}
          {{ cart.total_price | money }}
        {%- endif -%}
      </span>
    </div>

    <div class="pvh-mono pvh-rcpt-divider pvh-rcpt-divider--final">================================</div>

    <p class="pvh-mono pvh-rcpt-vat">
      * Incl. VAT. Final taxes calculated at checkout.
    </p>

  <!-- ── Receipt footer ──────────────────────────── -->
  <div class="pvh-rcpt-footer">
    <p class="pvh-mono pvh-rcpt-thanks">
      * &nbsp; * &nbsp; THANK&nbsp;YOU! &nbsp; * &nbsp; *
    </p>
    <p class="pvh-mono pvh-rcpt-fine">
      Your pet will love this order.
    </p>
    <p class="pvh-mono pvh-rcpt-fine pvh-rcpt-fine--xs">
      Questions? support@petvitalshub.com
    </p>
  </div>

</div>
{%- comment -%} Torn paper ::after is defined in pvh-receipt-drawer.liquid <style> {%- endcomment -%}

{%- else -%}
  <p class="pvh-mono pvh-rcpt-empty">
    Your cart is empty
  </p>
{%- endif -%}

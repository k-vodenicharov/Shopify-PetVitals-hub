      <div class="pvh-ts-title">Non-Toxic</div>
      <div class="pvh-ts-sub">Food-grade PP plastic</div>
    </div>
  </div>

  <!-- Badge 3: Fast Shipping -->
  <div class="pvh-ts-badge" role="listitem">
    <div class="pvh-ts-icon pvh-ts-icon--ship" aria-hidden="true">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
        <rect x="1" y="3" width="15" height="13" rx="1"/>
        <path d="M16 8h4l3 3v5h-7V8z"/>
        <circle cx="5.5" cy="18.5" r="2.5"/>

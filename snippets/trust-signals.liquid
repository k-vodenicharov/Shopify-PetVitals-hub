  </div>

  <!-- Badge 2: Non-Toxic -->
  <div class="pvh-ts-badge" role="listitem">
    <div class="pvh-ts-icon pvh-ts-icon--leaf" aria-hidden="true">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
        <path d="M2 22L12 12"/>
